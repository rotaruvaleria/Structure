#Задача 24. Построение Max-Heap за O(n) — build_max_heap
#Вопрос: Почему сложность O(n), а не O(n log n)?
import time
def grup(arr, n, i):
    while True:
        a = i
        left = 2 * i + 1
        right = 2 * i + 2

        if left < n and arr[left] > arr[a]:
            a = left
        if right < n and arr[right] > arr[a]:
            a = right
        if a != i:
            arr[i], arr[a] = arr[a], arr[i]
            i = a
        else:
            break


def cborka_kuchi(arr):
    n = len(arr)
    for i in range(n // 2 - 1, -1, -1):
        print(f"Обрабатываем позицию {i} (значение {arr[i]})")
        grup(arr, n, i)
        print(f"Массив сейчас: {arr}")
    return arr

arr = [4, 1, 3, 2, 16, 9, 10, 14, 8, 7]
print("Исходный:", arr)
result = cborka_kuchi(arr)
print("\nРезультат:", result)

start_time = time.time()
end_time = time.time()
print(f"Время выполнения: {(end_time - start_time)*1000:.10f} миллисекунд")

#Ожидаемый результат: Итог: [16,14,10,8,7,9,3,2,4,1]. Сложность O(n) из-за неравномерного распределения работы по уровням.






Для больших массивов разница огромная:

На нижних уровнях много элементов, но они делают мало шагов

На верхних уровнях мало элементов, но они делают много шагов

В сумме получается O(n) — то есть время растёт пропорционально размеру массива, а не быстрее.
Уровень 0: позиция 0 (1 элемент)
Уровень 1: позиции 1, 2 (2 элемента)
Уровень 2: позиции 3, 4, 5, 6 (4 элемента)
Уровень 3: позиции 7, 8, 9 (4 элемента, последний неполный)
