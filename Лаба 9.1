#include <iostream>

int max3(int a, int b, int c) {
    if (a >= b && a >= c) {
        return a;
    } else if (b >= c) {
        return b;
    } else {
        return c;
    }
}

int main() {
    // (1, 2, 3)
    int a = 1, b = 2, c = 3;
    int result = max3(a, b, c);
    std::cout << "Ожидаемый результат: max3(1, 2, 3) = 3" << std::endl;
    std::cout << "Результат: max3(" << a << ", " << b << ", " << c << ") = " << result << std::endl;

    // (5, 5, 5)
    a = 5, b = 5, c = 5;
    result = max3(a, b, c);
    std::cout << std::endl;
    std::cout << "Ожидаемый результат: max3(5, 5, 5) = 5" << std::endl;
    std::cout << "Результат: max3(" << a << ", " << b << ", " << c << ") = " << result << std::endl;

    // (-1, -2, -3)
    a = -1, b = -2, c = -3;
    result = max3(a, b, c);
    std::cout << std::endl;
    std::cout << "Ожидаемый результат: max3(-1, -2, -3) = -1" << std::endl;
    std::cout << "Результат: max3(" << a << ", " << b << ", " << c << ") = " << result << std::endl;

    // (0, 10, -5)
    a = 0, b = 10, c = -5;
    result = max3(a, b, c);
    std::cout << std::endl;
    std::cout << "Ожидаемый результат: max3(0, 10, -5) = 10" << std::endl;
    std::cout << "Результат: max3(" << a << ", " << b << ", " << c << ") = " << result << std::endl;

    std::cout << std::endl;
    std::cout << "1. Сколько ветвей if необходимо? - 2 ветви: if и elif" << std::endl;
    std::cout << "2. Запишите решение через вложенный тернарный оператор." << std::endl;
    std::cout << "max3 = [](int a, int b, int c) { return a >= b && a >= c ? a : (b >= c ? b : c); }" << std::endl;
    
    auto max3_lambda = [](int a, int b, int c) { return a >= b && a >= c ? a : (b >= c ? b : c); };
    std::cout << "Пример на (1, 2, 3) - max3(1, 2, 3) = " << max3_lambda(1, 2, 3) << std::endl;
    
    std::cout << "3. Что произойдёт, если все три числа равны? - Функция вернет это же число(в зависимости от порядка)" << std::endl;

    return 0;
}