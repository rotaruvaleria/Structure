import sys
def fibonacci_gen():
    a, b = 0, 1
    while True:
        yield a
        a, b = b, a + b
def take(gen, n):
    return [next(gen) for _ in range(n)]
def primes_gen():
    yield 2
    composites = {}
    candidate = 3
    while True:
        prime = composites.pop(candidate, None)
        if prime is None:
            yield candidate
            composites[candidate * candidate] = candidate
        else:
            next_multiple = candidate + prime * 2
            while next_multiple in composites:
                next_multiple += prime * 2
            composites[next_multiple] = prime
        candidate += 2


# Демонстрация
if __name__ == "__main__":
    print("Фибоначчи:", take(fibonacci_gen(), 10))
    print("Простые числа:", take(primes_gen(), 10))
    print("\n18. Сравнение потребления памяти:")
    fib_gen = fibonacci_gen()
