#Задача 4. Дан массив целых чисел длины n. Реализовать алгоритм создания нового массива из положительных элементов исходного. 
#          Определить дополнительную пространственную сложность в лучшем O(1), среднем O(n/2) и худшем O(n) случаях.

print("Программа создания нового массива из положительных элементов исходного")
while True:
    try:
        arr = list(map(int, input("Введите элементы массива через пробел: ").split()))
        if len(arr) == 0:
            print("Ошибка! Массив не может быть пустым")
            continue
        break
    except ValueError:
        print("Ошибка! Введите целые числа через пробел")

new_arr = []
for i in arr:
    if i > 0:
        new_arr.append(i)
print(f"Исходный массив: {arr}")

if len(new_arr) > 0:
    print(f"Новый массив из положительных элементов: {new_arr}")
else:
    print("В исходном массиве нет положительных элементов")

print("Анализ дополнительной пространственной сложности:")
print("Лучший случай O(1): массиве нет положительных элементов, тогда новый массив остается пустым (память не выделяется)")
print("Средний случай O(n/2): примерно половина элементов положительна, тогда новый массив занимает примерно n/2 ячеек памяти")
print("Худший случай O(n): все элементы положительны, тогда новый массив занимает n ячеек памяти")
print("Временная сложность: O(n) — один проход по исходному массиву")
