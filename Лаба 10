//     Интерфейс/абстрактный класс Drawable:
//            - draw( - нарисовать фигуру (вывести ASCII-арт или описание)
//            - resize(double factor) - масштабировать
//            - getDescription() - текстовое описание
// Реализующие классы: Circle, Square, Triangle, Star.
// Создайте List<Drawable> / vector<Drawable*> из 6 обьектов разных типов. Вызовите draw0 и resize() через указатель/ссылку базового типа.
// 34. Что такое динамический полиморфизм? Как он реализован в Java и С++?
// 35. Что такое vtable в C++? Зачем нужно ключевое слово virtual? 
#include <iostream>
#include <vector>
#include <memory>
#include <cmath>

class Drawable {
public:
    virtual void draw() const = 0;
    
    virtual void resize(double factor) {
    }
    
    virtual std::string getDescription() const = 0;
    
    virtual ~Drawable() {}
};

class Circle : public Drawable {
private:
    double radius;
    
public:
    Circle(double r) : radius(r) {}
    
    void draw() const override {
        std::cout << " ( o ) ";
    }
    
    void resize(double factor) override {
        radius = radius * factor;
    }
    
    std::string getDescription() const override {
        return "Круг с радиусом " + std::to_string(radius);
    }
};

class Square : public Drawable {
private:
    double side;
    
public:
    Square(double s) : side(s) {}
    
    void draw() const override {
        std::cout << " [====] ";
    }
    
    void resize(double factor) override {
        side = side * factor;
    }
    
    std::string getDescription() const override {
        return "Квадрат со стороной " + std::to_string(side);
    }
};

class Triangle : public Drawable {
private:
    double base;
    double height;
    
public:
    Triangle(double b, double h) : base(b), height(h) {}
    
    void draw() const override {
        std::cout << " /\\  ";
    }
    
    void resize(double factor) override {
        base = base * factor;
        height = height * factor;
    }
    
    std::string getDescription() const override {
        return "Треугольник (основание " + std::to_string(base) + 
               ", высота " + std::to_string(height) + ")";
    }
};

class Star : public Drawable {
private:
    double size;
    
public:
    Star(double s) : size(s) {}
    
    void draw() const override {
        std::cout << " * * * ";
    }
    
    void resize(double factor) override {
        size = size * factor;
    }
    
    std::string getDescription() const override {
        return "Звезда размера " + std::to_string(size);
    }
};

int main() {
    std::vector<Drawable*> shapes;
    
    shapes.push_back(new Circle(5.0));
    shapes.push_back(new Square(4.0));
    shapes.push_back(new Triangle(3.0, 4.0));
    shapes.push_back(new Star(2.0));
    shapes.push_back(new Circle(1.5));
    shapes.push_back(new Square(2.5));
    
    std::cout << "РИСУЕМ ФИГУРЫ:" << std::endl;
    for (Drawable* shape : shapes) {
        shape->draw();
    }
    std::cout << std::endl << std::endl;
    
    std::cout << "ОПИСАНИЕ ФИГУР (ДО МАСШТАБИРОВАНИЯ):" << std::endl;
    for (Drawable* shape : shapes) {
        std::cout << shape->getDescription() << std::endl;
    }
    std::cout << std::endl;
    
    double factor = 2.0;
    std::cout << "МАСШТАБИРУЕМ ВСЕ ФИГУРЫ В " << factor << " РАЗА" << std::endl;
    for (Drawable* shape : shapes) {
        shape->resize(factor);
    }
    std::cout << std::endl;
    
    std::cout << "ОПИСАНИЕ ФИГУР (ПОСЛЕ МАСШТАБИРОВАНИЯ):" << std::endl;
    for (Drawable* shape : shapes) {
        std::cout << shape->getDescription() << std::endl;
    }
    
    for (Drawable* shape : shapes) {
        delete shape;
    }
    shapes.clear();
    
		std::cout << std::endl;
    
    std::cout << "34. Что такое динамический полиморфизм? Как он реализован C++?" << std::endl;
    
    std::cout << "Динамический полиморфизм - это способность вызывать метод так, что решение" << std::endl;
    std::cout << "о том, какой именно метод выполнить, принимается во время работы программы," << std::endl;
    std::cout << "а не во время компиляции." << std::endl;
    std::cout << std::endl;
    std::cout << "Пример из кода: у нас есть указатель Drawable* shape, который может указывать" << std::endl;
    std::cout << "на Circle, Square, Triangle или Star. Когда мы пишем shape->draw()," << std::endl;
    std::cout << "компилятор не знает, какой именно draw() нужен. Во время выполнения" << std::endl;
    std::cout << "программа смотрит на реальный тип объекта и вызывает его draw()." << std::endl;
    std::cout << std::endl;
    std::cout << "Реализация:" << std::endl;
    std::cout << "  - В C++: используется ключевое слово virtual и таблица виртуальных функций (vtable)" << std::endl;
    std::cout << std::endl;
    
    std::cout << "35. Что такое vtable в C++? Зачем нужно ключевое слово virtual?" << std::endl;
    std::cout << "vtable - таблица виртуальных функций - указатели на реальные реализации." << std::endl;
    std::cout << std::endl;
    std::cout << "Как это работает:" << std::endl;
    std::cout << "  1. Для класса Circle компилятор создаёт таблицу Circle_vtable, где хранятся" << std::endl;
    std::cout << "     адреса методов: Circle::draw(), Circle::resize(), Circle::getDescription()" << std::endl;
    std::cout << "  2. Каждый объект Circle содержит скрытый указатель __vptr, который указывает на эту таблицу" << std::endl;
    std::cout << "  3. При вызове shape->draw() программа идёт по __vptr к vtable и берёт оттуда адрес draw()" << std::endl;
    std::cout << std::endl;
    std::cout << "Зачем нужно virtual:" << std::endl;
    std::cout << "  - Без virtual: метод вызывается по типу УКАЗАТЕЛЯ (статическое связывание)" << std::endl;
    std::cout << "  - С virtual: метод вызывается по типу ОБЪЕКТА (динамическое связывание)" << std::endl;
    std::cout << std::endl;
    std::cout << "Пример: если бы draw() не был virtual, то при вызове через Drawable* всегда" << std::endl;
    std::cout << "вызывался бы метод Drawable::draw() (или была бы ошибка), даже если объект - Circle." << std::endl;
    std::cout << "Благодаря virtual вызывается Circle::draw()." << std::endl;

    return 0;
}