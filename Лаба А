# Задача 4.  Дан массив целых чисел длины n. Реализовать алгоритм подсчёта количества чётных элементов.
#            Определить временную сложность и указать, к какому классу (O(1), O(n), O(n²) и т.д.) она относится.

print("Реализация алгоритма подсчета количества четных элементов массива")
while True:
    try:
        arr = list(map(int, input("Введите элементы через пробел: ").split()))
        if len(arr) == 0:
            print("Ошибка! Массив не может быть пустым")
            continue
        break
    except ValueError:
        print("Ошибка! Введите целые числа через пробел")
chet = 0
for i in arr:
    if i % 2 == 0:
        chet += 1

print(f"Количество четных элементов: {chet}")
print("Временная сложность: O(n) — один проход по массиву")
print("Доп. пространственная сложность: O(1) — одна переменная chet")
